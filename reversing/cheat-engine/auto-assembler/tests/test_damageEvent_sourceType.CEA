// ============================================================
// TEST: DamageEvent::sourceType Enum Enumeration
// ============================================================
//
// HYPOTHESIS
//   DamageEvent+0x04 (sourceType, uint32_t) is an enum that
//   distinguishes the damage-source category:
//   e.g. bullet, melee, grenade, vehicle crush, fall damage.
//   The value 4 already appears in the vehicle-seat check
//   inside damageEntity02, confirming it is an enum. We do
//   not yet know any other values.
//
// METHOD
//   Hook at damageEntity02 entry (halo1.dll+B9EA28) before
//   any parameters are modified.  At that point RCX holds
//   the DamageEvent* arg.  We snapshot four fields into
//   named static slots and bump a hit counter.  Add the
//   g_* labels to the CE memory list and read them after
//   each damage event.
//
//   Logged fields:
//     g_hitCount    DWORD  -- increments every call; use to
//                             confirm a new event fired
//     g_sourceType  DWORD  -- THE FIELD UNDER TEST
//     g_flags       DWORD  -- logged as context; expected to
//                             track headshot/instantkill, not
//                             source category
//     g_tagHandle   DWORD  -- damage effect tag handle; cross-
//                             reference via getTagName() to
//                             confirm what fired
//     g_baseDamage  Float  -- pre-modifier base damage
//
// PLAYER INSTRUCTIONS
//   1. Enable this script.
//   2. In the memory list, type each g_* name directly into
//      the address field (they are registered as global symbols).
//      Set types as listed above.
//   3. Trigger ONE damage type at a time on a live target.
//      Wait for g_hitCount to change, then record g_sourceType.
//      Suggested sequence (take notes as you go):
//        a) Pistol shot to body
//        b) Pistol shot to head  (expect same sourceType as (a))
//        c) Melee attack
//        d) Fragmentation grenade blast
//        e) Plasma grenade direct stick
//        f) Drive a Warthog into a biped (vehicle crush)
//        g) Fall damage (jump off a high ledge)
//        h) Rocket launcher indirect splash
//        i) Fuel rod gun direct hit
//        j) Plasma pistol overcharged bolt
//      Note: use a solo/LAN session so you can control the
//      scenario cleanly.
//
// PREDICTIONS
//   * sourceType changes across categories (a/c/d/f/g each
//     produce a distinct value).
//   * All bullet/projectile weapons share ONE sourceType value.
//   * Vehicle crush (f) produces value 4, matching the
//     vehicle-seat conditional seen in static analysis.
//   * Fall damage (g) may share a value with crush, or may
//     be its own category.
//   * Melee (c) gets a unique value.
//   * Grenade blast (d/e) shares a value with rocket splash (h)
//     if sourceType tracks the delivery mechanism rather than
//     the tag.
//   * g_flags varies per-hit (headshot bit etc.) but does NOT
//     change between, say, pistol body vs. melee -- that would
//     falsify the sourceType-as-enum hypothesis.
//
// HOOK SAFETY NOTE
//   The first 5 bytes of damageEntity02 are:
//     48 89 E0  -- MOV RAX,RSP
//     55        -- PUSH RBP
//     53        -- PUSH RBX
//   The hook overwrites these with a 5-byte relative JMP.
//   In the code cave we restore these exact bytes before
//   jumping back.  RAX is clobbered inside the cave, but
//   MOV RAX,RSP (the first original instruction) overwrites
//   it anyway, so there is no net change to register state.
//   RSP is never touched before MOV RAX,RSP executes.
//
// ============================================================

[ENABLE]

alloc(hookCode,   256, halo1.dll+B9EA28)
alloc(g_hitCount,   4, halo1.dll+B9EA28)
alloc(g_sourceType, 4, halo1.dll+B9EA28)
alloc(g_flags,      4, halo1.dll+B9EA28)
alloc(g_tagHandle,  4, halo1.dll+B9EA28)
alloc(g_baseDamage, 4, halo1.dll+B9EA28)
registersymbol(g_hitCount)
registersymbol(g_sourceType)
registersymbol(g_flags)
registersymbol(g_tagHandle)
registersymbol(g_baseDamage)

label(return)

hookCode:
  // RCX = DamageEvent* (first param, not yet modified)
  // RAX is free: first original instruction (MOV RAX,RSP)
  // will overwrite it, so we can use it as a scratch register.
  mov eax,[rcx]           // +0x00  damageTypeTagHandle
  mov [g_tagHandle],eax
  mov eax,[rcx+4]         // +0x04  sourceType  <-- hypothesis target
  mov [g_sourceType],eax
  mov eax,[rcx+8]         // +0x08  flags
  mov [g_flags],eax
  mov eax,[rcx+44]        // +0x44  baseDamage (raw float bits)
  mov [g_baseDamage],eax
  inc dword ptr [g_hitCount]
  // Restore overwritten prologue bytes
  mov rax,rsp
  push rbp
  push rbx
  jmp return

halo1.dll+B9EA28:
  jmp hookCode
return:

[DISABLE]

// Restore original prologue bytes: MOV RAX,RSP; PUSH RBP; PUSH RBX
halo1.dll+B9EA28:
  db 48 89 E0 55 53

dealloc(hookCode)
unregistersymbol(g_hitCount)
unregistersymbol(g_sourceType)
unregistersymbol(g_flags)
unregistersymbol(g_tagHandle)
unregistersymbol(g_baseDamage)
dealloc(g_hitCount)
dealloc(g_sourceType)
dealloc(g_flags)
dealloc(g_tagHandle)
dealloc(g_baseDamage)
