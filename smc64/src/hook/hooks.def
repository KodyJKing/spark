// One row per hookable engine function.
// Format: HOOK(Name, ReturnType, Offset, ArgTypes...)
//
// This file is included multiple times with different HOOK macro definitions.
// All types referenced here must be declared before the including header.

HOOK( TryPickInteractable,  void,     0xAD559CU, uint16_t, int16_t, uint32_t, int16_t             )
HOOK( UpdateFlareTransform, void,     0x8F7D70U, uint32_t                                          )
HOOK( SpawnProjectile,      uint32_t, 0xB35FD4U, Halo1::ProjectileSpawnArgs*, uint32_t             )
